.page-result {
  min-height: 100vh;
  background: #F0F5FF;
  padding-bottom: 200rpx;
}

.report-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  animation: slideDown 0.5s ease-out;
}

.header-healthy { background: linear-gradient(135deg, #10B981, #059669); }
.header-mild { background: linear-gradient(135deg, #F59E0B, #D97706); }
.header-medium { background: linear-gradient(135deg, #F97316, #EA580C); }
.header-severe { background: linear-gradient(135deg, #EF4444, #DC2626); }

.report-badge {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  animation: bounceIn 0.6s ease-out;
}

.badge-icon { font-size: 64rpx; }

.score-display {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.score-num {
  font-size: 96rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.score-max {
  font-size: 32rpx;
  color: rgba(255,255,255,0.7);
  margin-left: 4rpx;
}

.score-label {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  margin-bottom: 12rpx;
}

.report-time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.report-id {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 8rpx;
}

/* Detection Image */
.detection-image-wrap {
  position: relative;
  width: 100%;
  min-height: 400rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detection-image {
  width: 100%;
  height: auto;
}

.bbox-container {
  position: absolute;
  top: 0;
  left: 0;
}

.bbox-item {
  position: absolute;
  border: 3rpx solid;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.bbox-tag {
  position: absolute;
  top: -44rpx;
  left: -3rpx;
  display: flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 6rpx 6rpx 0 0;
  white-space: nowrap;
}

.bbox-tag-icon {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.bbox-tag-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
}

.bbox-tag-conf {
  font-size: 16rpx;
  color: rgba(255,255,255,0.85);
  margin-left: 6rpx;
}

/* Detection List */
.detection-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detection-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  transition: transform 0.2s;
}

.detection-item:active {
  transform: scale(0.98);
}

.det-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.det-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.det-icon { font-size: 36rpx; }

.det-info { flex: 1; }

.det-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
}

.det-desc {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 6rpx;
  display: block;
  line-height: 1.4;
}

.det-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.det-conf {
  font-size: 32rpx;
  font-weight: 800;
  color: #1E293B;
}

/* Tags */
.tag-healthy { background: #D1FAE5; color: #065F46; }
.tag-mild { background: #FEF3C7; color: #92400E; }
.tag-medium { background: #FFEDD5; color: #9A3412; }
.tag-severe { background: #FEE2E2; color: #991B1B; }

/* Healthy */
.healthy-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.healthy-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  animation: bounceIn 0.6s ease-out;
}

.healthy-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #065F46;
  margin-bottom: 16rpx;
}

.healthy-desc {
  font-size: 26rpx;
  color: #6B7280;
  text-align: center;
  line-height: 1.6;
}

/* Advice */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.advice-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #2563EB;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.advice-text {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.6;
  flex: 1;
}

.detail-text {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  display: block;
  margin-top: 16rpx;
}

/* Download */
.download-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: linear-gradient(135deg, #F0F5FF, #DBEAFE);
  border-radius: 16rpx;
  border: 2rpx dashed #93C5FD;
  transition: all 0.2s;
}

.download-btn:active {
  background: #DBEAFE;
  transform: scale(0.98);
}

.download-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.download-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2563EB;
}

/* Bottom Actions */
.bottom-actions {
  display: flex;
  padding: 24rpx;
  gap: 16rpx;
}

/* Disclaimer */
.disclaimer-card {
  margin: 24rpx;
  padding: 24rpx;
  background: #FFFBEB;
  border-radius: 16rpx;
  border-left: 6rpx solid #F59E0B;
}

.disclaimer-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 12rpx;
  display: block;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #78716C;
  line-height: 1.6;
  display: block;
}

/* Animations */
@keyframes slideDown {
  from { opacity: 0; transform: translateY(-40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes bounceIn {
  0% { opacity: 0; transform: scale(0.3); }
  50% { transform: scale(1.1); }
  70% { transform: scale(0.95); }
  100% { opacity: 1; transform: scale(1); }
}