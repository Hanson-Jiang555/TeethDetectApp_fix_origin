.page-index {
  min-height: 100vh;
  background: #F0F5FF;
}

.header {
  position: relative;
  height: 320rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #2563EB 0%, #3B82F6 50%, #60A5FA 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  padding: 60rpx 36rpx 40rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.greeting-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.quick-action {
  margin: -20rpx 24rpx 24rpx;
  background: linear-gradient(135deg, #2563EB, #1D4ED8);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
}

.action-main {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
}

.action-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.action-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
  display: block;
}

.action-arrow {
  font-size: 48rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 300;
}

.health-card {
  margin: 0 24rpx 24rpx;
}

.health-overview {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.score-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-ring.score-healthy { background: linear-gradient(135deg, #D1FAE5, #A7F3D0); }
.score-ring.score-mild { background: linear-gradient(135deg, #FEF3C7, #FDE68A); }
.score-ring.score-medium { background: linear-gradient(135deg, #FFEDD5, #FED7AA); }
.score-ring.score-severe { background: linear-gradient(135deg, #FEE2E2, #FECACA); }

.score-num {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
}

.score-num.score-healthy { color: #065F46; }
.score-num.score-mild { color: #92400E; }
.score-num.score-medium { color: #9A3412; }
.score-num.score-severe { color: #991B1B; }

.score-unit {
  font-size: 20rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

.health-info {
  flex: 1;
}

.health-status {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.status-healthy { background: #D1FAE5; color: #065F46; }
.status-mild { background: #FEF3C7; color: #92400E; }
.status-medium { background: #FFEDD5; color: #9A3412; }
.status-severe { background: #FEE2E2; color: #991B1B; }

.health-detail {
  font-size: 26rpx;
  color: #4B5563;
  display: block;
  line-height: 1.5;
}

.health-time {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 12rpx;
  display: block;
}

.stats-row {
  display: flex;
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(37, 99, 235, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #2563EB;
}

.stat-label {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E7EB;
}

.tips-card {
  margin: 0 24rpx 24rpx;
}

.tips-swiper {
  height: 80rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.tip-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.5;
}

.disclaimer {
  text-align: center;
  padding: 20rpx 24rpx 40rpx;
}

.disclaimer text {
  font-size: 22rpx;
  color: #9CA3AF;
}