<view class="page-index">
  <!-- Header -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="greeting">
        <text class="greeting-text">{{greeting}}，{{userInfo.nickName || '用户'}}</text>
        <text class="greeting-sub">今天也要关注牙齿健康哦</text>
      </view>
    </view>
  </view>

  <!-- Quick Action -->
  <view class="quick-action fade-in" bindtap="startDetect">
    <view class="action-main">
      <text class="action-icon">📷</text>
      <view class="action-info">
        <text class="action-title">开始检测</text>
        <text class="action-desc">拍照AI分析口腔健康状况</text>
      </view>
      <text class="action-arrow">›</text>
    </view>
  </view>

  <!-- Health Overview -->
  <view class="card health-card fade-in" wx:if="{{latestRecord}}">
    <view class="section-title">
      <view class="icon"></view>
      <text>最近检测</text>
    </view>
    <view class="health-overview">
      <view class="score-ring">
        <text class="score-num score-{{latestRecord.severityLabel}}">{{latestRecord.score}}</text>
        <text class="score-unit">分</text>
      </view>
      <view class="health-info">
        <view class="health-status status-{{latestRecord.severityLabel}}">
          <text>{{latestRecord.statusText}}</text>
        </view>
        <text class="health-detail">{{latestRecord.summary}}</text>
        <text class="health-time">{{latestRecord.dateStr}}</text>
      </view>
    </view>
  </view>

  <!-- No Record -->
  <view class="card fade-in" wx:if="{{!latestRecord}}">
    <view class="empty-state">
      <text class="icon">🦷</text>
      <text class="text">还没有检测记录</text>
      <text class="text" style="margin-top:8rpx;font-size:24rpx">点击上方「开始检测」进行第一次口腔检查</text>
    </view>
  </view>

  <!-- Stats -->
  <view class="stats-row fade-in" wx:if="{{totalChecks > 0}}">
    <view class="stat-item">
      <text class="stat-num">{{totalChecks}}</text>
      <text class="stat-label">累计检测</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{avgScore}}</text>
      <text class="stat-label">平均分数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{latestRecord.severityLabel === 'healthy' ? '良好' : latestRecord.severityLabel === 'mild' ? '注意' : latestRecord.severityLabel === 'medium' ? '警告' : '严重'}}</text>
      <text class="stat-label">最新状态</text>
    </view>
  </view>

  <!-- Tips Card -->
  <view class="card tips-card fade-in">
    <view class="section-title">
      <view class="icon"></view>
      <text>护齿小贴士</text>
    </view>
    <swiper class="tips-swiper" vertical autoplay circular interval="3000" duration="500">
      <swiper-item wx:for="{{tips}}" wx:key="index">
        <view class="tip-item">
          <text class="tip-emoji">{{item.icon}}</text>
          <text class="tip-text">{{item.text}}</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- Disclaimer -->
  <view class="disclaimer fade-in">
    <text>⚠️ 本工具仅供口腔健康初筛参考，不能替代专业牙科诊断</text>
  </view>
</view>