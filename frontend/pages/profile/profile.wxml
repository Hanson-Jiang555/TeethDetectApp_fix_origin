<view class="page-profile">
  <!-- User Info Header -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="user-info" wx:if="{{userInfo.nickName}}" bindtap="chooseAvatar">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/default_avatar.png'}}" mode="aspectFill"></image>
        <view class="user-detail">
          <text class="user-name">{{userInfo.nickName}}</text>
          <text class="user-gender">{{userInfo.gender === 1 ? '👨 男' : userInfo.gender === 2 ? '👩 女' : '👤 未设置'}}</text>
        </view>
      </view>
      <view class="login-area" wx:if="{{!userInfo.nickName}}" bindtap="login">
        <view class="avatar-placeholder">
          <text>👤</text>
        </view>
        <text class="login-text">点击登录</text>
      </view>
    </view>
  </view>

  <!-- Stats Cards -->
  <view class="stats-grid fade-in">
    <view class="stat-card">
      <text class="stat-emoji">📸</text>
      <text class="stat-num">{{totalChecks}}</text>
      <text class="stat-label">累计检测</text>
    </view>
    <view class="stat-card">
      <text class="stat-emoji">📈</text>
      <text class="stat-num">{{avgScore}}</text>
      <text class="stat-label">健康均分</text>
    </view>
    <view class="stat-card">
      <text class="stat-emoji">📅</text>
      <text class="stat-num">{{latestDate}}</text>
      <text class="stat-label">最近检测</text>
    </view>
  </view>

  <!-- Menu List -->
  <view class="card menu-card fade-in">
    <view class="menu-item" bindtap="goHistory">
      <text class="menu-icon">📋</text>
      <text class="menu-text">检测记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="editProfile">
      <text class="menu-icon">✏️</text>
      <text class="menu-text">编辑资料</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="showDisclaimer">
      <text class="menu-icon">⚠️</text>
      <text class="menu-text">免责声明</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- Logout -->
  <view class="card fade-in" wx:if="{{userInfo.nickName}}">
    <view class="logout-btn" bindtap="logout">
      <text>退出登录</text>
    </view>
  </view>

  <!-- App Info -->
  <view class="app-info fade-in">
    <text class="version">SmileGuard 护齿管家 v1.0.0</text>
    <text class="copyright">Made with ❤️</text>
  </view>
</view>