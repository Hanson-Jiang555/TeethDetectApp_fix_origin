.page-history {
  min-height: 100vh;
  background: #F0F5FF;
  padding-bottom: 140rpx;
}

.trend-card { margin: 24rpx; }

.chart-area { margin: 0 -8rpx; }
.trend-canvas { width: 100%; height: 300rpx; }

.chart-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200rpx;
}

.placeholder-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.placeholder-text { font-size: 24rpx; color: #9CA3AF; }

.trend-summary {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 24rpx;
  margin-top: 24rpx;
}

.trend-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trend-label { font-size: 22rpx; color: #9CA3AF; margin-bottom: 8rpx; }
.trend-value { font-size: 36rpx; font-weight: 800; color: #2563EB; }
.trend-high { color: #10B981 !important; }
.trend-low { color: #EF4444 !important; }

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.header-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.action-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #2563EB;
  border: 1rpx solid #DBEAFE;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.action-btn:active { background: #EFF6FF; }
.action-btn.danger { color: #EF4444; border-color: #FEE2E2; }
.action-btn.danger:active { background: #FEF2F2; }
.action-btn.batch-active { background: #2563EB; color: #fff; border-color: #2563EB; }

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.history-item.selected {
  background: #EFF6FF;
  border-color: #2563EB;
}

.item-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.checkbox {
  padding: 12rpx 8rpx 12rpx 0;
}

.checkbox-inner {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
  transition: all 0.2s;
}

.checkbox-inner.checked {
  background: #2563EB;
  border-color: #2563EB;
  color: #fff;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.item-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.status-healthy { background: #D1FAE5; }
.status-mild { background: #FEF3C7; }
.status-medium { background: #FFEDD5; }
.status-severe { background: #FEE2E2; }

.item-status {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
}

.item-date {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
  display: block;
}

.item-detail {
  font-size: 20rpx;
  color: #6B7280;
  margin-top: 4rpx;
  display: block;
}

.item-right {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.item-score { font-size: 40rpx; font-weight: 800; }
.score-healthy { color: #10B981; }
.score-mild { color: #F59E0B; }
.score-medium { color: #F97316; }
.score-severe { color: #EF4444; }

.item-unit { font-size: 20rpx; color: #9CA3AF; }

.item-actions {
  display: flex;
  gap: 8rpx;
  margin-left: 12rpx;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #F0F5FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transition: all 0.2s;
}

.action-icon-active { background: #DBEAFE; transform: scale(0.9); }
.action-icon.danger { background: #FEF2F2; }

/* Empty */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; font-weight: 700; color: #4B5563; margin-bottom: 12rpx; }
.empty-desc { font-size: 24rpx; color: #9CA3AF; }