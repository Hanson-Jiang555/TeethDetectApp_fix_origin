<view class="page-camera">
  <!-- Header tip -->
  <view class="camera-tip" wx:if="{{!photoPath && !analyzing && !errorMsg}}">
    <view class="tip-badge">💡</view>
    <text class="tip-content">{{tipText}}</text>
  </view>

  <!-- Error display -->
  <view class="error-card" wx:if="{{errorMsg}}">
    <view class="error-icon-wrap">
      <text class="error-icon">😕</text>
    </view>
    <text class="error-title">{{errorTitle}}</text>
    <text class="error-msg">{{errorMsg}}</text>
    <view class="btn-primary" bindtap="retryPhoto" style="margin-top:32rpx">重新拍照</view>
  </view>

  <!-- Photo preview -->
  <view class="preview-area" wx:if="{{photoPath && !analyzing}}">
    <view class="preview-frame">
      <image src="{{photoPath}}" mode="aspectFit" class="preview-img"></image>
    </view>
    <view class="preview-hint">✅ 照片已就绪，点击开始检测</view>
    <view class="preview-actions">
      <view class="btn-secondary" bindtap="retakePhoto" style="flex:1;margin-right:16rpx">重拍</view>
      <view class="btn-primary" bindtap="startAnalyze" style="flex:2">开始AI检测</view>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-area" wx:if="{{analyzing}}">
    <view class="loading-animation">
      <view class="loading-circle"></view>
      <text class="loading-emoji">🦷</text>
    </view>
    <text class="loading-title">AI正在分析中...</text>
    <text class="loading-desc">正在检测牙齿健康状况，请稍候</text>
    <view class="loading-progress">
      <view class="progress-bar" style="width: {{progress}}%"></view>
    </view>
    <text class="loading-step">{{loadingStep}}</text>
  </view>

  <!-- Camera area -->
  <view class="camera-area" wx:if="{{!photoPath && !analyzing && !errorMsg}}">
    <view class="camera-guide">
      <view class="guide-circle">
        <text class="guide-emoji">😄</text>
      </view>
      <text class="guide-text">将面部对准上方区域</text>
      <text class="guide-text">张大嘴巴露出牙齿</text>
    </view>

    <view class="camera-buttons">
      <view class="camera-btn main-btn" bindtap="takePhoto">
        <view class="btn-circle">
          <view class="btn-inner"></view>
        </view>
        <text class="btn-label">拍照检测</text>
      </view>
      <view class="camera-btn album-btn" bindtap="choosePhoto">
        <text class="album-icon">🖼️</text>
        <text class="btn-label">从相册选择</text>
      </view>
    </view>
  </view>
</view>