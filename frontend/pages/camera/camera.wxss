.page-camera {
  min-height: 100vh;
  background: #F0F5FF;
  display: flex;
  flex-direction: column;
}

.camera-tip {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  margin: 24rpx;
  border-radius: 20rpx;
  border-left: 8rpx solid #2563EB;
}

.tip-badge {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tip-content {
  font-size: 26rpx;
  color: #1E40AF;
  flex: 1;
}

.error-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
}

.error-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #FEF3C7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.error-icon {
  font-size: 80rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.error-msg {
  font-size: 28rpx;
  color: #6B7280;
  text-align: center;
  line-height: 1.6;
}

.preview-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
}

.preview-frame {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.preview-img {
  width: 100%;
  height: 100%;
}

.preview-hint {
  text-align: center;
  font-size: 28rpx;
  color: #10B981;
  font-weight: 600;
  padding: 24rpx 0;
}

.preview-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.loading-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.loading-animation {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 40rpx;
}

.loading-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid #E5E7EB;
  border-top-color: #2563EB;
  animation: spin 1s linear infinite;
  position: absolute;
  top: 0; left: 0;
}

.loading-emoji {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 72rpx;
}

.loading-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 12rpx;
}

.loading-desc {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 48rpx;
}

.loading-progress {
  width: 400rpx;
  height: 12rpx;
  background: #E5E7EB;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #2563EB, #3B82F6);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.loading-step {
  font-size: 24rpx;
  color: #9CA3AF;
}

.camera-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
}

.camera-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.guide-circle {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  border: 4rpx dashed #93C5FD;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.guide-emoji {
  font-size: 120rpx;
}

.guide-text {
  font-size: 30rpx;
  color: #4B5563;
  font-weight: 500;
}

.camera-buttons {
  display: flex;
  align-items: center;
  gap: 48rpx;
}

.camera-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563EB, #1D4ED8);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.4);
}

.btn-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  opacity: 0.3;
}

.main-btn .btn-label {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #2563EB;
  font-weight: 600;
}

.album-btn {
  margin-left: 32rpx;
}

.album-icon {
  font-size: 72rpx;
  margin-bottom: 8rpx;
}

.album-btn .btn-label {
  font-size: 26rpx;
  color: #6B7280;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}