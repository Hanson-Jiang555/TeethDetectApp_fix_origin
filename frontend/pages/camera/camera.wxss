.guide-card { margin-bottom: 24rpx; }
.guide-step {
  display: flex; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  color: #999;
}
.guide-step.active { color: #333; }
.step-num {
  width: 48rpx; height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #eee;
  border-radius: 50%;
  margin-right: 20rpx;
  font-weight: 700;
}
.guide-step.active .step-num { background: #4A90D9; color: #fff; }
.check { margin-left: auto; color: #52c41a; }
.error-card { text-align: center; padding: 60rpx 30rpx; }
.error-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.error-text { font-size: 28rpx; color: #e74c3c; display: block; margin-bottom: 30rpx; }
.preview-card { margin-bottom: 24rpx; }
.preview-img { width: 100%; border-radius: 16rpx; }
.preview-actions { display: flex; gap: 20rpx; margin-top: 24rpx; }
.preview-actions view { flex: 1; }
.btn-secondary {
  background: #f0f0f0; color: #666;
  border-radius: 50rpx; padding: 24rpx 0;
  font-size: 30rpx; text-align: center; font-weight: 600;
}
.loading-card { text-align: center; padding: 80rpx 30rpx; }
.loading-spinner {
  width: 80rpx; height: 80rpx;
  border: 6rpx solid #eee;
  border-top-color: #4A90D9;
  border-radius: 50%;
  margin: 0 auto 30rpx;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { display: block; font-size: 32rpx; color: #333; font-weight: 600; }
.loading-sub { display: block; font-size: 24rpx; color: #999; margin-top: 12rpx; }
.camera-area { display: flex; gap: 20rpx; justify-content: center; margin-top: 40rpx; }
.camera-btn {
  flex: 1; text-align: center; padding: 30rpx;
  background: #f0f4f8; border-radius: 16rpx;
}
.camera-icon { font-size: 48rpx; display: block; margin-bottom: 12rpx; }
.camera-text { font-size: 26rpx; color: #666; }
.choose-btn { background: #e8f4f8; }
